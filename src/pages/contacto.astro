---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contacto | La Querencia Hotel">
  <section id="contacto" class="bg-[#f5f2ea] py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h1 class="text-4xl font-semibold text-center mb-12">Contáctanos</h1>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- FORMULARIO -->

        <div class="bg-white p-8 rounded-xl shadow-md">
          <h2 class="text-2xl font-semibold mb-6">Envíanos un mensaje</h2>

          <form
            action="https://formsubmit.co/jfpintov@hotmail.com"
            method="POST"
            autocomplete="off"
            class="space-y-5"
          >
            <!-- anti spam -->
            <input type="hidden" name="_captcha" value="false" />
            <input type="text" name="_honey" style="display:none" />

            <!-- redirección -->
            <input
              type="hidden"
              name="_next"
              value="https://laquerenciahr.com/contacto"
            />

            <div>
              <label class="block text-sm mb-1">Nombre</label>
              <input
                type="text"
                name="name"
                placeholder="Tu nombre"
                required
                class="w-full border rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
              />
            </div>

            <div>
              <label class="block text-sm mb-1">Correo electrónico</label>
              <input
                type="email"
                name="email"
                placeholder="tu@email.com"
                required
                class="w-full border rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
              />
            </div>

            <div>
              <label class="block text-sm mb-1">Mensaje</label>
              <textarea
                name="message"
                rows="4"
                placeholder="Escribe tu consulta..."
                required
                class="w-full border rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
              ></textarea>
            </div>

            <button
              type="submit"
              class="bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition"
            >
              Enviar mensaje
            </button>
          </form>
        </div>

        <!-- INFORMACIÓN DEL HOTEL -->

        <div class="space-y-6">
          <div class="bg-white p-6 rounded-xl shadow-md">
            <h2 class="text-2xl font-semibold mb-4">Información del Hotel</h2>

            <p class="mb-2">
              📍 Panamericana Sur Km 97.5<br />
              Asia, Lima - Perú
            </p>

            <p class="mb-2">📞 953 678 592</p>

            <p class="mb-2">✉ jfpintov@hotmail.com</p>

            <a
              href="https://wa.me/51953678592"
              target="_blank"
              class="inline-block mt-4 bg-green-500 text-white px-5 py-2 rounded-lg hover:bg-green-600 transition"
            >
              Reservar por WhatsApp
            </a>
          </div>

          <!-- MAPA -->

          <div class="bg-white p-2 rounded-xl shadow-md overflow-hidden">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d891.7351882199786!2d-76.60228962698358!3d-12.76499389277683!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMTLCsDQ1JzU0LjUiUyA3NsKwMzYnMDguNSJX!5e1!3m2!1ses!2spe!4v1738964642154!5m2!1ses!2spe"
              width="100%"
              height="250"
              style="border:0"
              loading="lazy"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
