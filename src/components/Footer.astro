---

<footer class="bg-[#f5f2ec] border-t border-gray-200 mt-16">

  <div class="max-w-6xl mx-auto px-6 py-8 grid md:grid-cols-3">

    <!-- Logo -->
    <div class="flex justify-center md:justify-start items-center md:border-r md:border-gray-300 pr-8">
      <img
        src="/querenciahotellogo.png"
        alt="La Querencia Hotel"
        class="h-20 w-auto object-contain"
      />
    </div>

    <!-- Contacto -->
    <div class="space-y-3 text-gray-700 text-sm md:text-base md:border-r md:border-gray-300 px-8">

      <div class="flex items-center gap-3">
        <img src="/llamar.png" class="w-5 h-5"/>
        <span>953 678 592</span>
      </div>

      <div class="flex items-center gap-3">
        <img src="/correo.png" class="w-5 h-5"/>
        <span>jfpintov@hotmail.com - laquerenciahr@gmail.com</span>
      </div>

      <div class="flex items-start gap-3">
        <img src="/ubicacion.png" class="w-5 h-5 mt-1"/>
        <span>
          Panamericana Sur Km 97.5<br>
          Asia, Lima - Perú
        </span>
      </div>

    </div>

    <!-- Navegación -->
    <div class="flex flex-col items-center md:items-end gap-3 text-gray-700 pl-8">

      <a
        href="/habitaciones"
        class="hover:text-green-600 transition font-medium"
      >
        Habitaciones
      </a>

      <a
        href="/contacto"
        class="hover:text-green-600 transition font-medium"
      >
        Contáctenos
      </a>

    </div>

  </div>

  <!-- línea inferior -->
  <div class="max-w-4xl mx-auto border-t border-gray-300"></div>

  <!-- copyright -->
  <div class="text-center text-sm text-gray-500 py-4">
    © {new Date().getFullYear()} La Querencia Hotel — Todos los derechos reservados
  </div>

</footer>